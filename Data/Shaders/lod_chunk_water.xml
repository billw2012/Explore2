<effect name = "lod_chunk_water">
  <state
    GL_DEPTH_TEST = "true"
    GL_CULL_FACE = "false"
  />
  <vert_program>
    <file name = "lod_chunk_water_vs.glsl"/>
    <map_param source = "MODELVIEWPROJMAT" target = "uModelViewProj" />
    <map_param source = "MODELVIEWMAT" target = "uModelView" />
    <map_param source = "PlanetCenterOffset" target = "uPlanetCenterOffset" />
  </vert_program>
  <frag_program>
    <file name = "lod_chunk_water_fs.glsl"/>
    <map_param source = "MODELVIEWMAT" target = "uModelView" />
    <map_param source = "PlanetIndex" target = "uPlanetIndex" />
  </frag_program>
</effect>
