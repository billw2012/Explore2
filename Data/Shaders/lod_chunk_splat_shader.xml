<effect name = "lod_chunk_splat_shader">
  <state
    GL_DEPTH_TEST = "false"
    GL_CULL_FACE = "false"
    GL_BLEND = "true"
    glBlendFunc = "GL_SRC_ALPHA, GL_ONE_MINUS_SRC_ALPHA"
  />
  <vert_program>
    <file name = "lod_chunk_splat_shader_vs.glsl"/>
    <map_param source = "MODELVIEWPROJMAT" target = "uModelViewProj" />
  </vert_program>
  <frag_program>
    <file name = "lod_chunk_splat_shader_fs.glsl"/>
    <map_param source = "ColourTexture" target = "uColourTexture" />
  </frag_program>
</effect>
