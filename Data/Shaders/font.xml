<effect name = "font">
  <state
    GL_DEPTH_TEST = "false"
    GL_CULL_FACE = "false"
  />
  <vert_program>
    <file name = "font_vs.glsl"/>
    <map_param source = "MODELVIEWPROJMAT" target = "uModelViewProj" />
  </vert_program>
  <frag_program>
    <file name = "font_fs.glsl"/>
    <map_param source = "FontTexture" target = "fontTexture" />
  </frag_program>
</effect>
